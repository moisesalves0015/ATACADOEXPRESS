rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, phone, role, address, cpf, totalPurchases, createdAt
    // NOTE: role is set to 'client' on registration.
    //       To grant admin access, manually set role: "admin" in Firebase Console.
    //
    // Collection: products
    // Fields: name, description, category, stockType, availableQuantity, unitPrice,
    //         requiredGoal, currentGoalProgress, estimatedArrivalDate, imageUrl, status, goalReached
    //
    // Collection: orders
    // Fields: clientId, clientName, orderDate, totalValue, status,
    //         paymentProofUrl, observations, items
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin is determined ONLY by the role field in the Firestore user document.
    // Never rely on email. Set role: "admin" manually in Firebase Console.
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.role in ['admin', 'client'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'stockType', 'unitPrice', 'status']) &&
             data.stockType in ['pronta_entrega', 'previsao_meta'] &&
             data.status in ['active', 'inactive'] &&
             data.unitPrice is number && data.unitPrice >= 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['clientId', 'orderDate', 'totalValue', 'status']) &&
             data.status in ['aguardando_pagamento', 'pagamento_confirmado', 'separacao', 'enviado', 'entregue', 'cancelado'] &&
             data.totalValue is number && data.totalValue >= 0 &&
             data.clientId is string && data.clientId.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{uid} {
      // Users can read their own profile; admins can read all
      allow read: if isOwner(uid) || isAdmin();

      // On register: authenticated user can create their own doc.
      // The role field cannot be 'admin' — only admins can create admin accounts.
      allow create: if isAuthenticated() &&
                       isOwner(uid) &&
                       isValidUser(request.resource.data) &&
                       request.resource.data.role == 'client';

      // User can update their own profile but CANNOT change their own role.
      // Admin can update any profile including role changes.
      allow update: if isValidUser(request.resource.data) &&
                    (
                      isAdmin() ||
                      (isOwner(uid) && request.resource.data.role == resource.data.role)
                    );

      allow delete: if isAdmin();
    }

    // Products collection — public read, admin-only write for metadata, client update for stock
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableQuantity', 'currentGoalProgress', 'goalReached'])
      );
    }

    // Orders collection
    match /orders/{orderId} {
      // Admin sees all; client sees only their own
      allow read: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);

      // Client can create orders for themselves only; admin can create for any client
      allow create: if isAuthenticated() &&
                       isValidOrder(request.resource.data) &&
                       (isAdmin() || request.resource.data.clientId == request.auth.uid);

      // Client can only update paymentProofUrl/observations while status is aguardando_pagamento
      // Admin can update any field
      allow update: if isAdmin() ||
                    (isAuthenticated() &&
                     resource.data.clientId == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentProofUrl', 'observations']) &&
                     resource.data.status == 'aguardando_pagamento');

      allow delete: if isAdmin();
    }

    // Phone Mappings collection - used for login lookups
    match /phoneMappings/{phone} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
